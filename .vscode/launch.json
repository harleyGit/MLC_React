{
    // VS Code 调试配置文件
    // 点击左上角运行按钮 -> 选择「🧪[Debug]启动MLC」-> 终端启动 Vite -> 在当前 Chrome 中打开新标签页
    "version": "0.2.0",
    "configurations": [
        {
            // 类型：node-terminal 表示在 VS Code 终端中运行命令
            "type": "node-terminal",
            // 请求：launch 表示启动新的终端会话
            "request": "launch",
            // 配置名称：显示在调试面板下拉菜单中
            "name": "🧪[Debug]启动MLC",
            // 执行启动脚本：
            // 1. 检查 5174 端口是否已有服务
            // 2. 如果没有，后台启动 npm run dev 并等待端口就绪
            // 3. 使用 open -a 在当前 Chrome 中打开新标签页
            // 4. wait 保持终端运行，让 Vite 持续服务
            "command": "${workspaceFolder}/.vscode/start-dev.sh"
        }
    ]
}
