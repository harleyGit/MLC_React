{
    // VS Code 调试配置文件
    // 点击 VS Code 左上角运行按钮时：
    // 1. 如果 5174 端口已有 Vite 服务，直接复用它。
    // 2. 如果 5174 端口没有服务，先执行 npm run dev 启动 Vite。
    // 3. 服务可访问后，明确使用 Google Chrome 打开 http://localhost:5174/。
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node-terminal",
            "request": "launch",
            "name": "🧪[Debug]启动MLC",
            // 使用 node-terminal 是为了只运行终端命令，不让 VS Code 附加 Chrome 调试端口。
            // 这样可以避免“无法附加到浏览器”，并复用当前已打开的 Chrome。
            "command": "sh",
            "args": [
                "-c",
                // lsof 检查 5174 端口是否已有服务监听。
                // - 已有服务：跳过 npm run dev，避免 Vite 报 Port 5174 is already in use。
                // - 没有服务：后台启动 npm run dev，然后等待 5174 端口就绪。
                // 最后用 open -a 固定打开 Google Chrome，避免打开 Safari 或默认浏览器。
                "if ! lsof -nP -iTCP:5174 -sTCP:LISTEN >/dev/null 2>&1; then npm run dev & while ! lsof -nP -iTCP:5174 -sTCP:LISTEN >/dev/null 2>&1; do sleep 0.2; done; fi; open -a 'Google Chrome' 'http://localhost:5174/'; wait"
            ]
        }
    ]
}
